{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://engloopkit.dev/schemas/retrieval-cases.schema.json",
  "title": "EngLoopKit clean-context learning retrieval cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["cases"],
  "properties": {
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "expectedCardIds", "expectedSourceIds", "tags", "expectGap"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 1 },
          "expectedCardIds": { "type": "array", "items": { "type": "string" } },
          "expectedSourceIds": { "type": "array", "items": { "type": "string", "pattern": "^PM[0-9]{3}/LEARN[0-9]{3}$" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "expectGap": { "type": "boolean" }
        }
      }
    }
  }
}
